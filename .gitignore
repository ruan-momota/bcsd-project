# --- Python 通用忽略 ---
__pycache__/
*.py[cod]
*$py.class

# --- Jupyter Notebook 垃圾文件 ---
.ipynb_checkpoints/

# --- VS Code 配置 (个人配置不上传) ---
.vscode/

# 忽略原始二进制数据集
data/raw/
# 忽略处理后的巨大JSON文件 (如果很大就忽略，小的话可以保留)
data/

# 忽略训练产出 (日志和模型权重)
outputs/
*.pth
*.bin

# 忽略环境文件夹 (不要把conda环境传上去)
bcsd_env/
bcsd/
env/
venv/

# 忽略 Mac/Windows 系统文件
.DS_Store
Thumbs.db